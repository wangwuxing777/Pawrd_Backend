# Pawrd Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration
# Production (Zeabur / Docker)
DATABASE_URL=postgresql://user:password@hostname:port/dbname
# Fallback local configurations (optional)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=pawrd

# RAG Service (Insurance AI)
RAG_SERVICE_URL=http://localhost:8001

# Google Maps API (for clinic/vet location services)
MAPS_API_KEY=your_google_maps_api_key_here

# Shopify Storefront API Configuration
# Get these from your Shopify admin: Settings > Apps and sales channels > Develop app
SHOPIFY_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token_here

# Stripe PaymentSheet Configuration
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Mock Mode (for development without real Shopify credentials)
# Set to "true" to use mock data instead of calling real Shopify API
USE_MOCK_SHOPIFY=false

# Multi-agent health report extraction (placeholders)
# Set up to 3 vendors. Leave endpoint empty to disable a vendor.
REPORT_AGENT_1_ID=vendor_a
REPORT_AGENT_1_ENDPOINT=
REPORT_AGENT_1_API_KEY=
REPORT_AGENT_1_MODEL=MODEL_A
REPORT_AGENT_1_RELIABILITY=0.80

REPORT_AGENT_2_ID=vendor_b
REPORT_AGENT_2_ENDPOINT=
REPORT_AGENT_2_API_KEY=
REPORT_AGENT_2_MODEL=MODEL_B
REPORT_AGENT_2_RELIABILITY=0.85

REPORT_AGENT_3_ID=vendor_c
REPORT_AGENT_3_ENDPOINT=
REPORT_AGENT_3_API_KEY=
REPORT_AGENT_3_MODEL=MODEL_C
REPORT_AGENT_3_RELIABILITY=0.90

# Tencent COS (Hong Kong recommended)
# Example bucket URL: https://<bucket-appid>.cos.ap-hongkong.myqcloud.com
COS_SECRET_ID=YOUR_COS_SECRET_ID
COS_SECRET_KEY=YOUR_COS_SECRET_KEY
COS_BUCKET_NAME=YOUR_BUCKET_NAME
COS_BUCKET_URL=YOUR_BUCKET_URL
COS_SIGNED_URL_EXPIRE_SECONDS=900
